# 이 파일을 복사해 .env.development / .env.test 로 만들고 값을 채우세요.
#   cp .env.example .env.development
# 실제 .env.* 파일은 .gitignore로 추적되지 않습니다. (.env.example만 추적)

# ── 환경 ──────────────────────────────
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# ── 데이터베이스 (MariaDB) ─────────────
# Prisma 연결 문자열
DATABASE_URL="mysql://root:root@localhost:3306/app_db"
# seed/raw 연결용 개별 값
DB_HOST=localhost
DB_PORT=3306
DB_NAME=app_db
DB_USER=root
DB_PASSWORD=root
DB_CONNECTION_LIMIT=10

# ── JWT (사용자) ──────────────────────
JWT_ACCESS_SECRET=change-me-user-access-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=3600

# ── JWT (관리자) ──────────────────────
ADMIN_JWT_ACCESS_SECRET=change-me-admin-access-secret
ADMIN_JWT_ACCESS_TOKEN_EXPIRES_IN=1800

# ── 로깅 ──────────────────────────────
LOG_LEVEL=debug
LOG_DIRECTORY=logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# ── 스케줄러 ──────────────────────────
# 고아 업로드 파일 정리 크론 (예: 매일 새벽 4시)
ORPHAN_CLEANUP_CRON=0 4 * * *
